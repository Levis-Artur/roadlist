generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Officer {
  id          String   @id @default(uuid())
  badgeNumber String   @unique
  fullName    String
  department  String
  pinHash     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vehicle {
  id                 String   @id @default(uuid())
  plateNumber        String   @unique
  displayPlateNumber String?
  brand              String
  model              String
  department         String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  monthlyRouteSheets VehicleMonthlyRouteSheet[]

  @@index([department, isActive])
}

model VehicleMonthlyRouteSheet {
  id                   String       @id @default(uuid())
  vehicleId            String
  vehicleNumber        String
  displayVehicleNumber String?
  vehicleBrand         String
  vehicleModel         String
  department           String
  year                 Int
  month                Int
  status               String       @default("open")
  openingOdometer      Int?
  closingOdometer      Int?
  totalDistanceKm      Int          @default(0)
  totalFuelLiters      Float        @default(0)
  printedAt            DateTime?
  closedAt             DateTime?
  archivedAt           DateTime?
  adminCheckedBy       String?
  adminComment         String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  vehicle              Vehicle      @relation(fields: [vehicleId], references: [id])
  shiftEntries         RouteSheet[]

  @@unique([vehicleId, year, month])
  @@index([vehicleNumber, year, month])
  @@index([status])
}

model RouteSheet {
  id                   String                    @id @default(uuid())
  monthlyRouteSheetId  String?
  monthlyRouteSheet    VehicleMonthlyRouteSheet? @relation(fields: [monthlyRouteSheetId], references: [id])
  badgeNumber          String
  fullName             String
  department           String
  crewNumber           String?
  vehicleId            String?
  vehicleNumber        String
  displayVehicleNumber String?
  vehicleBrand         String?
  vehicleModel         String?
  startOdometer        Int
  endOdometer          Int?
  distanceKm           Int?
  startPhotoId         String?
  endPhotoId           String?
  startOcrValue        Int?
  endOcrValue          Int?
  startManualEntry     Boolean
  endManualEntry       Boolean?
  refueled             Boolean                   @default(false)
  fuelLiters           Float?
  adminVerifiedAt      DateTime?
  adminVerifiedBy      String?
  adminReviewComment   String?
  status               String
  startedAt            DateTime
  endedAt              DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  photos               OdometerPhoto[]

  @@index([badgeNumber, status])
  @@index([crewNumber, vehicleNumber, status])
  @@index([vehicleNumber, status])
  @@index([monthlyRouteSheetId])
  @@index([createdAt])
}

model OdometerPhoto {
  id           String      @id @default(uuid())
  routeSheetId String?
  routeSheet   RouteSheet? @relation(fields: [routeSheetId], references: [id], onDelete: SetNull)
  type         String
  filePath     String
  originalName String?
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime    @default(now())
  expiresAt    DateTime
  deletedAt    DateTime?

  @@index([routeSheetId])
  @@index([expiresAt, deletedAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String?
  badgeNumber String?
  details     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}
