generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String?  @unique
  region    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  units     DepartmentUnit[]

  @@index([isActive])
  @@index([region])
}

model DepartmentUnit {
  id           String     @id @default(uuid())
  departmentId String
  name         String
  type         String?
  code         String?
  description  String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id])

  @@unique([departmentId, name])
  @@index([departmentId, isActive])
}

model Officer {
  id          String   @id @default(uuid())
  badgeNumber String   @unique
  fullName    String
  department  String
  unit        String?
  departmentId String?
  departmentName String?
  departmentUnitId String?
  departmentUnitName String?
  pinHash     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([departmentId, isActive])
  @@index([departmentUnitId, isActive])
}

model Vehicle {
  id                 String   @id @default(uuid())
  plateNumber        String   @unique
  displayPlateNumber String?
  brand              String
  model              String
  department         String
  unit               String?
  departmentId       String?
  departmentName     String?
  departmentUnitId   String?
  departmentUnitName String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  monthlyRouteSheets VehicleMonthlyRouteSheet[]
  transferHistory    VehicleTransferHistory[]

  @@index([department, isActive])
  @@index([departmentId, isActive])
  @@index([departmentUnitId, isActive])
}

model VehicleTransferHistory {
  id                    String   @id @default(uuid())
  vehicleId             String
  vehicleNumber         String
  displayVehicleNumber  String?
  fromDepartment        String?
  fromUnit              String?
  fromDepartmentId      String?
  fromDepartmentName    String?
  fromDepartmentUnitId  String?
  fromDepartmentUnitName String?
  toDepartment          String
  toUnit                String?
  toDepartmentId        String?
  toDepartmentName      String?
  toDepartmentUnitId    String?
  toDepartmentUnitName  String?
  comment               String?
  transferredByAdminId  String?
  transferredByUsername String?
  transferredByRole     String?
  transferredAt         DateTime @default(now())
  vehicle               Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([toDepartment, toUnit])
  @@index([toDepartmentId, toDepartmentUnitId])
  @@index([transferredAt])
}

model VehicleMonthlyRouteSheet {
  id                   String       @id @default(uuid())
  vehicleId            String
  vehicleNumber        String
  displayVehicleNumber String?
  vehicleBrand         String
  vehicleModel         String
  department           String
  unit                 String?
  departmentId         String?
  departmentName       String?
  departmentUnitId     String?
  departmentUnitName   String?
  year                 Int
  month                Int
  status               String       @default("open")
  openingOdometer      Int?
  closingOdometer      Int?
  totalDistanceKm      Int          @default(0)
  totalFuelLiters      Float        @default(0)
  printedAt            DateTime?
  closedAt             DateTime?
  archivedAt           DateTime?
  adminCheckedBy       String?
  adminComment         String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  vehicle              Vehicle      @relation(fields: [vehicleId], references: [id])
  shiftEntries         RouteSheet[]

  @@unique([vehicleId, year, month])
  @@index([vehicleNumber, year, month])
  @@index([status])
  @@index([departmentId, departmentUnitId])
}

model RouteSheet {
  id                   String                    @id @default(uuid())
  monthlyRouteSheetId  String?
  monthlyRouteSheet    VehicleMonthlyRouteSheet? @relation(fields: [monthlyRouteSheetId], references: [id])
  badgeNumber          String
  fullName             String
  department           String
  unit                 String?
  departmentId         String?
  departmentName       String?
  departmentUnitId     String?
  departmentUnitName   String?
  crewNumber           String?
  vehicleId            String?
  vehicleNumber        String
  displayVehicleNumber String?
  vehicleBrand         String?
  vehicleModel         String?
  startOdometer        Int
  endOdometer          Int?
  distanceKm           Int?
  startPhotoId         String?
  endPhotoId           String?
  startOcrValue        Int?
  endOcrValue          Int?
  startManualEntry     Boolean
  endManualEntry       Boolean?
  refueled             Boolean                   @default(false)
  fuelLiters           Float?
  adminVerifiedAt      DateTime?
  adminVerifiedBy      String?
  adminReviewComment   String?
  status               String
  startedAt            DateTime
  endedAt              DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  photos               OdometerPhoto[]

  @@index([badgeNumber, status])
  @@index([crewNumber, vehicleNumber, status])
  @@index([vehicleNumber, status])
  @@index([monthlyRouteSheetId])
  @@index([createdAt])
  @@index([departmentId, departmentUnitId])
}

model OdometerPhoto {
  id           String      @id @default(uuid())
  routeSheetId String?
  routeSheet   RouteSheet? @relation(fields: [routeSheetId], references: [id], onDelete: SetNull)
  type         String
  filePath     String
  originalName String?
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime    @default(now())
  expiresAt    DateTime
  deletedAt    DateTime?

  @@index([routeSheetId])
  @@index([expiresAt, deletedAt])
}

model AdminUser {
  id                  String    @id @default(uuid())
  username            String    @unique
  fullName            String
  role                String
  department          String?
  unit                String?
  departmentId        String?
  departmentName      String?
  passwordHash        String
  isActive            Boolean   @default(true)
  mustChangePassword  Boolean   @default(false)
  passwordChangedAt   DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?
  twoFactorEnabledAt  DateTime?
  twoFactorLastVerifiedAt DateTime?
  twoFactorRecoveryCodesHash String?
  createdById         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([role, isActive])
  @@index([department, isActive])
  @@index([departmentId, isActive])
  @@index([lockedUntil])
  @@index([twoFactorEnabled])
}

model AuditLog {
  id                String   @id @default(uuid())
  action            String
  entityType        String
  entityId          String?
  badgeNumber       String?
  details           String?
  ipAddress         String?
  userAgent         String?
  actorAdminId      String?
  actorUsername     String?
  actorRole         String?
  actorDepartment   String?
  actorUnit         String?
  actorDepartmentId String?
  targetAdminId     String?
  targetRole        String?
  targetDepartment  String?
  targetUnit        String?
  targetDepartmentId String?
  createdAt         DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([actorRole, actorDepartment])
}
